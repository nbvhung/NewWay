# Backend Configuration
# Copy to .env for local development
# Railway: set these via Dashboard (do NOT use .env on Railway)

PORT=4000

# PostgreSQL — Railway auto-provides DATABASE_URL
# Local: DATABASE_HOST, DATABASE_PORT, DATABASE_USER, DATABASE_PASSWORD, DATABASE_NAME
DATABASE_URL=
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=newway

# Redis — Railway auto-provides REDIS_URL
# Local: REDIS_HOST, REDIS_PORT
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your-access-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# Frontend URLs for CORS — comma-separated, Railway: set to frontend Railway & Vercel URLs
# e.g. http://localhost:3000,https://fe-production.up.railway.app,https://fe-xxx.vercel.app
CORS_ORIGIN=http://localhost:3000

# Seed accounts — creates on first run if not exists
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_SUPPER_PASSWORD=supper123

# Seed sample shipping lines
SEED_SHIPPING_LINES=true
